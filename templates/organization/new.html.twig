{% extends 'base.html.twig' %}

{% block title %}Nouvelle organisation — TaskFlow{% endblock %}

{% block body %}
    <div class="card">
        <h1>Nouvelle organisation</h1>
        {{ form_start(form) }}
            {{ form_row(form.name) }}
            <div class="form-actions">
                <button type="submit" class="btn">Créer l'organisation</button>
                <a class="btn btn-secondary" href="{{ path('app_organization_index') }}">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
