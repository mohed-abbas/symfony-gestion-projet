{% extends 'base.html.twig' %}

{% block title %}Inscription — TaskFlow{% endblock %}

{% block body %}
    <div class="card">
        <h1>Créer un compte</h1>

        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}

        {{ form_errors(registrationForm) }}

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.email, { label: 'E-mail' }) }}
            {{ form_row(registrationForm.plainPassword, { label: 'Mot de passe' }) }}
            {{ form_row(registrationForm.agreeTerms, { label: "J'accepte les conditions d'utilisation" }) }}

            <button type="submit">S'inscrire</button>
        {{ form_end(registrationForm) }}

        <p class="muted" style="margin-top:1rem">Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a></p>
    </div>
{% endblock %}
