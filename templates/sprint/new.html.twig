{% extends 'base.html.twig' %}

{% block title %}Nouveau sprint — {{ project.name }}{% endblock %}

{% block body %}
    <div class="card wide">
        <h1>Nouveau sprint — {{ project.name }}</h1>
        {{ form_start(form) }}
            {{ form_row(form.name) }}
            {{ form_row(form.goal) }}
            <div style="display:flex; gap:1rem">
                <div style="flex:1">{{ form_row(form.startDate) }}</div>
                <div style="flex:1">{{ form_row(form.endDate) }}</div>
            </div>
            <div class="form-actions">
                <button class="btn">Créer le sprint</button>
                <a class="btn btn-secondary" href="{{ path('app_project_backlog', {id: project.id}) }}">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
