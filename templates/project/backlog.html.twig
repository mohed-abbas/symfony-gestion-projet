{% extends 'base.html.twig' %}

{% block title %}Backlog — {{ project.name }}{% endblock %}
{% block main_class %}wide{% endblock %}

{% macro task_row(task) %}
    <tr>
        <td><a href="{{ path('app_task_show', {id: task.id}) }}">{{ task.title }}</a></td>
        <td><span class="badge badge-{{ task.type }}">{{ task.type }}</span></td>
        <td><span class="badge badge-{{ task.priority }}">{{ task.priority }}</span></td>
        <td class="muted">{{ task.assignee ? task.assignee.fullName : '—' }}</td>
    </tr>
{% endmacro %}

{% block body %}
    {% import _self as helper %}
    <div class="row-between" style="margin-bottom:1rem">
        <h1 style="margin:0">{{ project.name }} — Backlog</h1>
        <div class="form-actions">
            <a class="btn btn-secondary" href="{{ path('app_project_board', {id: project.id}) }}">Kanban</a>
            {% if is_granted(constant('App\\Security\\Voter\\ProjectVoter::EDIT'), project) %}
                <a class="btn btn-secondary" href="{{ path('app_sprint_new', {id: project.id}) }}">+ Sprint</a>
            {% endif %}
            <a class="btn btn-sm" href="{{ path('app_task_new', {id: project.id}) }}">+ Tâche</a>
        </div>
    </div>

    {% for entry in bySprint %}
        <div class="card wide">
            <div class="row-between">
                <h1 style="font-size:1.1rem; margin:0">{{ entry.sprint.name }}</h1>
                {% if is_granted(constant('App\\Security\\Voter\\ProjectVoter::EDIT'), project) %}
                    <span class="form-actions">
                        <a class="btn btn-secondary btn-sm" href="{{ path('app_sprint_edit', {id: entry.sprint.id}) }}">Modifier</a>
                        <form class="inline-form" method="post" action="{{ path('app_sprint_delete', {id: entry.sprint.id}) }}"
                              onsubmit="return confirm('Supprimer ce sprint ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_sprint_' ~ entry.sprint.id) }}">
                            <button class="btn btn-danger btn-sm">Suppr.</button>
                        </form>
                    </span>
                {% endif %}
            </div>
            {% if entry.sprint.goal %}<p class="muted" style="margin:.3rem 0">{{ entry.sprint.goal }}</p>{% endif %}
            <table><tbody>
                {% for task in entry.tasks %}{{ helper.task_row(task) }}{% endfor %}
            </tbody></table>
        </div>
    {% endfor %}

    <div class="card wide">
        <h1 style="font-size:1.1rem; margin:0 0 .5rem">Backlog (sans sprint)</h1>
        {% if backlog is empty %}
            <p class="muted">Aucune tâche non planifiée.</p>
        {% else %}
            <table><tbody>
                {% for task in backlog %}{{ helper.task_row(task) }}{% endfor %}
            </tbody></table>
        {% endif %}
    </div>
{% endblock %}
