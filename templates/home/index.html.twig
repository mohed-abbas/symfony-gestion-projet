{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — TaskFlow{% endblock %}

{% block body %}
    <div class="card wide">
        <h1>Bienvenue sur {{ title }}</h1>
        <p class="muted">Connecté en tant que <strong>{{ app.user.fullName ?: app.user.userIdentifier }}</strong>.</p>
        <ul class="roles">
            {% for role in app.user.roles %}
                <li>{{ role }}</li>
            {% endfor %}
        </ul>
        <div class="form-actions">
            <a class="btn" href="{{ path('app_project_index') }}">Mes projets</a>
        </div>
    </div>
{% endblock %}
