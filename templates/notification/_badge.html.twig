<a href="{{ path('app_notification_index') }}" class="notif-link" aria-label="Notifications{% if unread > 0 %} ({{ unread }} non lues){% endif %}">
    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M10 2.5a4.5 4.5 0 0 0-4.5 4.5c0 3.5-1.3 4.8-1.8 5.3-.2.2-.2.5 0 .7.1.1.3.2.5.2h11.6c.2 0 .4-.1.5-.2.2-.2.2-.5 0-.7-.5-.5-1.8-1.8-1.8-5.3A4.5 4.5 0 0 0 10 2.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        <path d="M8.5 16a1.6 1.6 0 0 0 3 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    </svg>
    {% if unread > 0 %}<span class="notif-badge">{{ unread > 99 ? '99+' : unread }}</span>{% endif %}
</a>
