<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}TaskFlow{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%2296%22>✅</text></svg>">
        {% block stylesheets %}
            <style>
                :root { --bg:#f4f5f7; --card:#fff; --line:#e2e4e9; --brand:#2563eb; --text:#1f2430; --muted:#6b7280; }
                * { box-sizing: border-box; }
                body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background:var(--bg); color:var(--text); }
                header.nav { display:flex; align-items:center; justify-content:space-between; padding:.8rem 1.4rem; background:var(--card); border-bottom:1px solid var(--line); }
                header.nav a.brand { font-weight:700; color:var(--brand); text-decoration:none; font-size:1.15rem; }
                header.nav nav a { color:var(--text); text-decoration:none; margin-left:1rem; font-size:.92rem; }
                header.nav nav a:hover { color:var(--brand); }
                main { max-width:960px; margin:2rem auto; padding:0 1.2rem; }
                .card { background:var(--card); border:1px solid var(--line); border-radius:12px; padding:1.6rem; max-width:420px; margin:2.5rem auto; }
                .card.wide { max-width:100%; }
                h1 { margin-top:0; font-size:1.5rem; }
                label { display:block; margin:.7rem 0 .25rem; font-size:.85rem; color:var(--muted); }
                input:not([type=checkbox]), select, textarea { width:100%; padding:.55rem .7rem; border:1px solid var(--line); border-radius:8px; font-size:.95rem; }
                button, .btn { background:var(--brand); color:#fff; border:0; border-radius:8px; padding:.6rem 1.1rem; font-size:.95rem; cursor:pointer; margin-top:1rem; text-decoration:none; display:inline-block; }
                button:hover, .btn:hover { filter:brightness(.94); }
                .alert { padding:.6rem .8rem; border-radius:8px; margin-bottom:1rem; font-size:.9rem; }
                .alert-danger { background:#fdecec; color:#b42318; }
                .alert-success { background:#e7f6ec; color:#1b7f3b; }
                .muted { color:var(--muted); font-size:.88rem; }
                .field-row { margin-bottom:.4rem; }
                ul.roles { list-style:none; padding:0; display:flex; gap:.4rem; flex-wrap:wrap; }
                ul.roles li { background:#eef2ff; color:var(--brand); border-radius:20px; padding:.15rem .7rem; font-size:.78rem; }
                main.wide { max-width:1200px; }
                a { color:var(--brand); }
                .btn-secondary { background:#eef2ff; color:var(--brand); }
                .btn-danger { background:#fdecec; color:#b42318; }
                .btn-sm { padding:.32rem .7rem; font-size:.82rem; margin-top:0; }
                .row-between { display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
                .stack > * + * { margin-top:.6rem; }
                .badge { display:inline-block; border-radius:6px; padding:.1rem .5rem; font-size:.74rem; font-weight:600; }
                .badge-bug { background:#fdecec; color:#b42318; }
                .badge-feature { background:#e7f6ec; color:#1b7f3b; }
                .badge-story { background:#eef2ff; color:#3538cd; }
                .badge-high { background:#fdecec; color:#b42318; }
                .badge-medium { background:#fff4e5; color:#b25b00; }
                .badge-low { background:#eef2f5; color:#4b5563; }
                .badge-muted { background:#eef2f5; color:#4b5563; }
                table { width:100%; border-collapse:collapse; }
                th, td { text-align:left; padding:.55rem .6rem; border-bottom:1px solid var(--line); font-size:.9rem; }
                th { color:var(--muted); font-weight:600; font-size:.78rem; text-transform:uppercase; letter-spacing:.03em; }
                .grid { display:grid; gap:1rem; grid-template-columns:repeat(auto-fill, minmax(260px, 1fr)); }
                .board { display:grid; gap:1rem; grid-template-columns:repeat(4, 1fr); align-items:start; }
                .board .col { background:#eef0f3; border-radius:12px; padding:.7rem; min-height:120px; }
                .board .col.is-over { outline:2px dashed var(--brand); background:#e6edff; }
                .board .col h3 { margin:.1rem 0 .6rem; font-size:.85rem; text-transform:uppercase; letter-spacing:.03em; color:var(--muted); }
                .kcard { background:#fff; border:1px solid var(--line); border-radius:9px; padding:.55rem .65rem; margin-bottom:.55rem; cursor:grab; }
                .kcard:hover { border-color:var(--brand); }
                .kcard .kmeta { display:flex; gap:.35rem; align-items:center; margin-top:.4rem; flex-wrap:wrap; }
                .kcard a { text-decoration:none; color:var(--text); font-weight:500; font-size:.9rem; }
                .chip { display:inline-block; border-radius:20px; padding:.1rem .55rem; font-size:.72rem; color:#fff; }
                .form-actions { margin-top:1.2rem; display:flex; gap:.6rem; }
                .comment { border-bottom:1px solid var(--line); padding:.6rem 0; font-size:.9rem; }
                .comment .meta { color:var(--muted); font-size:.78rem; margin-bottom:.2rem; }
                fieldset { border:1px solid var(--line); border-radius:8px; padding:.6rem .9rem; margin:.6rem 0; }
                fieldset legend { font-size:.8rem; color:var(--muted); padding:0 .3rem; }
                .inline-form { display:inline; }
                .progress { background:var(--line); border-radius:20px; height:14px; overflow:hidden; }
                .progress-fill { background:var(--brand); height:100%; border-radius:20px; transition:width .3s; }
                .notif-link { position:relative; text-decoration:none; }
                .notif-badge { position:absolute; top:-8px; right:-10px; background:#ef4444; color:#fff; font-size:.68rem; font-weight:700; line-height:1; padding:.15rem .35rem; border-radius:10px; }
                .notif-item { display:flex; gap:.6rem; padding:.7rem 0; border-bottom:1px solid var(--line); }
                .notif-item.unread { font-weight:600; }
                .notif-item .dot { color:var(--brand); }
            </style>
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="nav">
            <a class="brand" href="{{ path('app_home') }}">✅ TaskFlow</a>
            <nav>
                {% if app.user %}
                    <a href="{{ path('app_project_index') }}">Projets</a>
                    {% if is_granted('ROLE_MANAGER') %}<a href="{{ path('app_organization_index') }}">Organisations</a>{% endif %}
                    {% if is_granted('ROLE_ADMIN') %}<a href="{{ path('app_admin_dashboard') }}">Admin</a>{% endif %}
                    {{ render(controller('App\\Controller\\NotificationController::badge')) }}
                    <span class="muted">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_logout') }}">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}">Connexion</a>
                    <a href="{{ path('app_register') }}">Inscription</a>
                {% endif %}
            </nav>
        </header>

        <main class="{% block main_class %}{% endblock %}">
            {% for label, messages in app.flashes(['success', 'error']) %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
