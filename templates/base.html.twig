<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}TaskFlow{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 32 32%22><rect width=%2232%22 height=%2232%22 rx=%226%22 fill=%22%2317181a%22/><path d=%22M9 16.5l4.5 4.5L23 11%22 stroke=%22white%22 stroke-width=%223%22 fill=%22none%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22/></svg>">
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% set route = app.request.attributes.get('_route') %}
        {% if app.user %}
            <div class="shell">
                <aside class="sidebar">
                    <a class="wordmark" href="{{ path('app_home') }}">
                        <span class="logo" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 32 32" fill="none"><path d="M8 16.5l5 5L24 10" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                        TaskFlow
                    </a>

                    <nav class="side-nav">
                        <a href="{{ path('app_project_index') }}" class="{{ route starts with 'app_project' or route starts with 'app_task' or route starts with 'app_sprint' ? 'is-active' }}">
                            <span class="ic" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="2.5" width="12" height="11" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></span>
                            Projets
                        </a>
                        {% if is_granted('ROLE_MANAGER') %}
                            <a href="{{ path('app_organization_index') }}" class="{{ route starts with 'app_organization' ? 'is-active' }}">
                                <span class="ic" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2.5 13.5V4l5-2 5 2v9.5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M6 13.5v-3h3.5v3M6 6h.5M9 6h.5M6 8.5h.5M9 8.5h.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg></span>
                                Organisations
                            </a>
                        {% endif %}
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('app_admin_dashboard') }}" class="{{ route starts with 'app_admin' ? 'is-active' }}">
                                <span class="ic" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2l5 2v3.5c0 3-2.1 5.4-5 6.5-2.9-1.1-5-3.5-5-6.5V4l5-2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg></span>
                                Admin
                            </a>
                        {% endif %}
                    </nav>

                    <div class="side-foot">
                        {{ render(controller('App\\Controller\\NotificationController::badge')) }}
                        <div class="side-user">
                            <span class="avatar" aria-hidden="true">{{ app.user.fullName ? app.user.fullName|slice(0,1) : app.user.userIdentifier|slice(0,1) }}</span>
                            <span class="who">
                                <span class="nm">{{ app.user.fullName ?: app.user.userIdentifier }}</span>
                                <span class="rl">{{ is_granted('ROLE_ADMIN') ? 'admin' : (is_granted('ROLE_MANAGER') ? 'manager' : 'member') }}</span>
                            </span>
                        </div>
                        <a class="side-logout" href="{{ path('app_logout') }}">Déconnexion</a>
                    </div>
                </aside>

                <div class="content">
                    <main class="{% block main_class %}{% endblock %}">
        {% else %}
            <div class="auth-wrap">
                <main>
                    <a class="auth-brand" href="{{ path('app_home') }}">
                        <span class="logo" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 32 32" fill="none"><path d="M8 16.5l5 5L24 10" stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </span>
                        TaskFlow
                    </a>
        {% endif %}

                        {% for label, messages in app.flashes(['success', 'error']) %}
                            {% for message in messages %}
                                <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }}">{{ message }}</div>
                            {% endfor %}
                        {% endfor %}
                        {% block body %}{% endblock %}

        {% if app.user %}
                    </main>
                </div>
            </div>
        {% else %}
                </main>
            </div>
        {% endif %}
    </body>
</html>
