        <h1>Modifier la tâche</h1>
        <div data-controller="dynamic-form">
            {% include 'task/_form.html.twig' with {
                button_label: 'Enregistrer',
                cancel_path: path('app_task_show', {id: task.id}),
                project: task.project,
            } %}
        </div>
    </div>
{% endblock %}
