# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Base dédiée aux tests. doctrine.yaml (when@test) ajoute le suffixe `_test` → base réelle
# = `app_test`, isolée de la base dev `app`. NB : dans ce projet Docker fixe DATABASE_URL en
# variable d'environnement (qui prime sur .env.test) → `make test` la ré-injecte via `-e`.
DATABASE_URL="postgresql://app:my-super-secret-password@database:5432/app?serverVersion=16&charset=utf8"
